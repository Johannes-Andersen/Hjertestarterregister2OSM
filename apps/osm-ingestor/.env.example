DATABASE_URL="postgres://username:password@localhost:5432/hjertestarterregister2osm"
OSM_PLANET_URL="https://download.geofabrik.de/europe/norway-latest.osm.pbf"
# Used as a local naming template. Daily builds are stored as data/norway-<timestamp>.osm.pbf.
OSM_PLANET_FILE_PATH="data/norway-latest.osm.pbf"
OSM_PLANET_RETAIN_DOWNLOADS="2"
OSM_REPLICATION_BASE_URL="https://planet.openstreetmap.org/replication/minute"
OSM_PLANET_BATCH_SIZE="500"
OSM_MAX_MINUTE_PATCHES_PER_JOB="10"
OSM_USER_AGENT="Hjertestarterregister2OSM/1.0 (https://github.com/Johannes-Andersen/Hjertestarterregister2OSM)"
LOG_LEVEL="info"
